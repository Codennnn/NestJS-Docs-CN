# ===========================================
# NestJS 中文文档项目 - 环境变量配置示例
# ===========================================
# 复制此文件为 .env.local（本地开发）或 .env.production（生产），
# 并根据实际情况填写配置值。切勿将含真实凭据的 .env 文件提交到版本控制。

# -------------------------------------------
# 环境标识
# -------------------------------------------
# Node.js 运行环境：development | production | test
NODE_ENV=development

# -------------------------------------------
# 站点域名（防盗链白名单）
# -------------------------------------------
# 生产环境填写实际域名（不含协议前缀），如：nestjs.example.com
# 本地开发保持 localhost 即可
NEXT_PUBLIC_SITE_DOMAIN=localhost

# -------------------------------------------
# Orama Cloud 搜索服务配置
# -------------------------------------------
# 从 https://cloud.orama.run 获取 API 密钥和索引端点
# 用于文档内容的全文搜索功能
NEXT_PUBLIC_ORAMA_API_KEY=your_orama_api_key_here
NEXT_PUBLIC_ORAMA_ENDPOINT=https://cloud.orama.run/v1/indexes/your_index_id
