# ===========================================
# NestJS 中文文档项目 - 环境变量配置示例
# ===========================================
# 复制此文件为 .env.local（本地开发）或 .env.production（生产），
# 并根据实际情况填写配置值。切勿将含真实凭据的 .env 文件提交到版本控制。

# -------------------------------------------
# 环境标识
# -------------------------------------------
# Node.js 运行环境：development | production | test
NODE_ENV=development

# 站点公开访问地址（用于 metadata / sitemap / robots / 结构化数据）
# 本地开发可保持默认值；生产环境请替换为实际域名
NEXT_PUBLIC_SITE_URL=http://localhost:8080

# -------------------------------------------
# Algolia 搜索服务配置
# -------------------------------------------
# 从 https://dashboard.algolia.com 获取 Application ID 和 API Key
# 用于文档内容的全文搜索功能
NEXT_PUBLIC_ALGOLIA_APP_ID=your_algolia_app_id_here
NEXT_PUBLIC_ALGOLIA_SEARCH_API_KEY=your_algolia_search_api_key_here
NEXT_PUBLIC_ALGOLIA_INDEX_NAME=nestjs_docs_cn

# Algolia Admin API Key（仅索引同步脚本使用，不可暴露到前端）
ALGOLIA_ADMIN_API_KEY=your_algolia_admin_api_key_here

# -------------------------------------------
# Orama Cloud AI 问答配置
# -------------------------------------------
# 从 https://app.orama.com 获取项目 ID 和 API 密钥
# 用于 AI 问答面板功能
NEXT_PUBLIC_ORAMA_PROJECT_ID=your_orama_project_id_here
NEXT_PUBLIC_ORAMA_API_KEY=your_orama_api_key_here
