{
  "name": "nestjs-docs-cn",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "next dev -p 8080",
    "build": "next build",
    "clean": "rimraf node_modules .next",
    "start": "next start -p 8080",
    "deps": "pnpm up --interactive --latest",
    "lint": "run-p lint:ts lint:es lint:css",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:es": "eslint \"**/*.{ts,tsx}\"",
    "lint:ts": "tsc",
    "format:docs": "prettier --write \"src/content/docs/**/*.mdx\"",
    "algolia:sync": "tsx scripts/sync-algolia.ts",
    "algolia:dry-run": "DRY_RUN=true tsx scripts/sync-algolia.ts"
  },
  "dependencies": {
    "@base-ui/react": "1.4.0",
    "@mdx-js/mdx": "^3.1.0",
    "@next/mdx": "16.2.3",
    "@orama/core": "^1.2.19",
    "@vercel/analytics": "^2.0.1",
    "algoliasearch": "^5.50.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "consola": "^3.4.2",
    "lodash-es": "^4.17.21",
    "lucide-react": "^1.8.0",
    "mermaid": "^11.7.0",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.9.17",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-use-event-hook": "^0.9.6",
    "tailwind-merge": "^3.3.1",
    "ufo": "^1.6.1"
  },
  "devDependencies": {
    "@shikijs/transformers": "^3.7.0",
    "@shikijs/twoslash": "^3.7.0",
    "@tailwindcss/postcss": "^4.1.10",
    "@tailwindcss/typography": "^0.5.16",
    "@types/lodash-es": "^4.17.12",
    "@types/mdx": "^2.0.13",
    "@types/node": "25.6.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "eslint": "^10.2.0",
    "eslint-config-next": "16.2.3",
    "npm-run-all2": "^8.0.4",
    "prefer-code-style": "^3.10.0",
    "prettier": "^3.6.0",
    "rehype-mdx-code-props": "^3.0.1",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "rimraf": "^6.1.3",
    "shiki": "^3.7.0",
    "stylelint": "^17.7.0",
    "stylelint-config-clean-order": "^8.0.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "tailwindcss": "^4.1.10",
    "tsx": "^4.19.2",
    "tw-animate-css": "^1.3.4"
  },
  "packageManager": "pnpm@9.15.3",
  "engines": {
    "node": ">=22"
  }
}
